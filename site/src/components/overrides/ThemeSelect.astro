---
// Override of @astrojs/starlight/components/ThemeSelect.astro.
// Replaces Starlight's 3-option <select> (auto / light / dark) with
// a single 36×36 icon button that flips between light and dark.
//
// Visible icon shows the CURRENT theme (sun in light, moon in dark),
// flipped via pure CSS off `:root[data-theme]` — no JS-driven swap
// needed. Click toggles, writes the new value to the same localStorage
// key Starlight uses ('starlight-theme'). The ThemeProvider override
// (./ThemeProvider.astro) handles the initial render.
//
// Wired in astro.config.mjs via `components.ThemeSelect`.
---

<button
	class="nbg-theme-toggle"
	type="button"
	aria-label="Toggle dark mode"
	data-nbg-theme-toggle
>
	<svg class="nbg-theme-toggle__icon nbg-theme-toggle__icon--sun"
		 viewBox="0 0 24 24" aria-hidden="true" focusable="false">
		<circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"></circle>
		<g stroke="currentColor" stroke-width="2" stroke-linecap="round">
			<line x1="12" y1="2"  x2="12" y2="5"></line>
			<line x1="12" y1="19" x2="12" y2="22"></line>
			<line x1="2"  y1="12" x2="5"  y2="12"></line>
			<line x1="19" y1="12" x2="22" y2="12"></line>
			<line x1="4.93"  y1="4.93"  x2="7.05"  y2="7.05"></line>
			<line x1="16.95" y1="16.95" x2="19.07" y2="19.07"></line>
			<line x1="4.93"  y1="19.07" x2="7.05"  y2="16.95"></line>
			<line x1="16.95" y1="7.05"  x2="19.07" y2="4.93"></line>
		</g>
	</svg>
	<svg class="nbg-theme-toggle__icon nbg-theme-toggle__icon--moon"
		 viewBox="0 0 24 24" aria-hidden="true" focusable="false">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
			  fill="none" stroke="currentColor" stroke-width="2"
			  stroke-linecap="round" stroke-linejoin="round"></path>
	</svg>
</button>

<style>
	.nbg-theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0;
		border-radius: 8px;
		background: var(--nbg-surface-2);
		border: 1px solid var(--nbg-hairline);
		color: var(--nbg-ink-2);
		cursor: pointer;
		transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
	}
	.nbg-theme-toggle:hover {
		color: var(--nbg-accent);
		border-color: var(--nbg-accent-soft);
	}
	.nbg-theme-toggle:focus-visible {
		outline: 2px solid var(--nbg-accent);
		outline-offset: 2px;
	}
	.nbg-theme-toggle__icon {
		width: 1rem;
		height: 1rem;
	}
	/* Show the icon for the CURRENT theme. */
	.nbg-theme-toggle__icon--sun  { display: block; }
	.nbg-theme-toggle__icon--moon { display: none; }
	:global(:root[data-theme='dark']) .nbg-theme-toggle__icon--sun  { display: none; }
	:global(:root[data-theme='dark']) .nbg-theme-toggle__icon--moon { display: block; }
</style>

<script>
	const STORAGE_KEY = 'starlight-theme';

	function apply(theme: 'light' | 'dark'): void {
		document.documentElement.dataset.theme = theme;
		try { localStorage.setItem(STORAGE_KEY, theme); } catch { /* private mode */ }
	}

	function onClick(e: Event): void {
		const target = e.target as Element | null;
		const btn = target?.closest?.('[data-nbg-theme-toggle]');
		if (!btn) return;
		const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
		apply(current === 'dark' ? 'light' : 'dark');
	}

	// Single delegated listener — survives view-transitions and works for
	// every toggle instance on the page (SplashAwareHeader mounts two:
	// one in the topnav, one in the mobile drawer).
	const w = window as unknown as { __nbgThemeToggleWired?: boolean };
	if (!w.__nbgThemeToggleWired) {
		document.addEventListener('click', onClick);
		w.__nbgThemeToggleWired = true;
	}
</script>
