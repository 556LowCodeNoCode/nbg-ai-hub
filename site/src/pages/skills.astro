---
/**
 * /skills — single-column reading flow, structural twin of /tips.
 *
 * 2026-06-02 rework:
 *   - Every row is now clickable through to /skills/{id}/ via the same
 *     `listing-row--linked` + `listing-row__title-link` pattern tips uses.
 *     Skill bodies (which previously rendered nowhere on the site) finally
 *     surface to readers.
 *   - New "NBG AI team plugin library" featured panel sits above the
 *     Internal / Community groups. Different visual treatment (gold accent,
 *     tinted background) so the team-built upstream reads as recommended,
 *     not as just another row. Links into the NBG-AI/claude-tools repo plus
 *     a TBD-during-rollout access-request note.
 *   - Internal-origin rows carry a gold left border so the cluster feels
 *     visually tied to the featured panel above.
 *
 * Earlier history (2026-05-25): hero scale matched to Foundations,
 * audience+topic filters integrated into the hero, skills grouped by origin.
 */
import { getCollection } from 'astro:content';
import MarketingShell from '../components/MarketingShell.astro';
import AudienceFilter from '../components/AudienceFilter.astro';
import TopicFilter from '../components/TopicFilter.astro';
import PinButton from '../components/PinButton.astro';
import { linkGlossaryTerms } from '../lib/glossary-link-string';
import '../styles/listing-rows.css';

const items = await getCollection('skills');

const allCategories = Array.from(
  new Set(items.map((s) => s.data.category)),
).sort();
const sorted = items.sort((a, b) => {
  const byDate = b.data.authored.localeCompare(a.data.authored);
  return byDate !== 0 ? byDate : a.data.title.localeCompare(b.data.title);
});

function audienceTooltip(a: string): string {
  if (a === 'beginner') return 'For colleagues new to Claude Code';
  if (a === 'advanced') return 'For experienced Claude Code users';
  return 'Applies to everyone';
}

/** Split a "command — explanation" title so we can render the parts separately. */
function splitTitle(title: string, fallbackId: string): { command: string; explanation: string } {
  const parts = title.split(' — ');
  if (parts.length < 2) {
    return { command: `/${fallbackId}`, explanation: title };
  }
  const head = parts[0]!;
  return {
    command: head.startsWith('/') ? head : `/${head}`,
    explanation: parts.slice(1).join(' — '),
  };
}

const GROUPS: Array<{ key: string; label: string; blurb: string; origin: string }> = [
  {
    key: 'internal',
    label: 'Built at NBG',
    blurb: 'Skills authored by the NBG AI team — tuned for our codebase, conventions, and compliance constraints.',
    origin: 'internal',
  },
  {
    key: 'community',
    label: 'From the community',
    blurb: 'Skills published by the wider Claude Code community — vetted by us and worth installing.',
    origin: 'community',
  },
];

const grouped = GROUPS.map((g) => ({
  ...g,
  items: sorted.filter((s) => String(s.data.origin) === g.origin),
}));
---

<MarketingShell
  title="Skills"
  description="The skills catalog — reusable Claude Code skills and plugins worth your attention."
  surfaceId="skills"
  width="full"
  hero="none"
>
  <section class="hero hero--stack">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Skills worth <em>installing</em></h1>
        <p class="hero__lede">
          <Fragment set:html={linkGlossaryTerms("A curated catalog of Claude Code skills and plugins — the ones we keep reaching for. Each entry tells you what the skill does, who it's for, the slash command you type in Claude, and how to install it.")} />
        </p>
      </div>
    </div>
  </section>

  {/* Sticky filter strip — sibling of the listing sections so it stays
      visible through the entire scroll, not just while the hero is on
      screen. Inner `.hero__filter` retains the existing chip layout
      styling that other CSS targets via that selector. */}
  <section class="listing-filter-bar" data-listing-filter-bar>
    <div class="wrap">
      <div class="hero__filter">
        <AudienceFilter scope=".listing-row[data-audience]" />
        <TopicFilter topics={allCategories} scope=".listing-row[data-topics]" />
      </div>
    </div>
  </section>

  <section class="section section--listing" style="padding-block-end: 0;">
    <div class="wrap">
      <aside class="listing-intro">
        <p class="listing-intro__eyebrow">What is a skill?</p>
        <p
          class="listing-intro__body"
          set:html={
            "A <strong>" + linkGlossaryTerms("skill") + "</strong> is a reusable workflow you install into " +
            linkGlossaryTerms("Claude Code") +
            " once and then call with a <strong>" + linkGlossaryTerms("slash command") + "</strong>. " +
            "Skills don't replace Claude — they teach it a specific way of working " +
            "(e.g. how we deploy, how we design schemas, how we run UAT) so you don't repeat the same instructions every session. " +
            "Click any entry below for the install steps and a worked scenario."
          }
        />
      </aside>
    </div>
  </section>

  {/* ─── Featured: the NBG AI team plugin library ────────────────── */}
  <section class="section section--listing skills-featured-wrap" style="padding-block: 1.25rem;">
    <div class="wrap">
      <article class="skills-featured">
        <p class="skills-featured__eyebrow">NBG AI team · plugin library</p>
        <h2 class="skills-featured__title"><code>NBG-AI/claude-tools</code> — the team's developer skill library</h2>
        <p class="skills-featured__lede">
          An internal plugin library at <a href="https://github.com/NBG-AI/claude-tools" target="_blank" rel="noopener"><code>NBG-AI/claude-tools</code></a> — ~40 advanced skills for engineers actively working on NBG software.
        </p>
        <p class="skills-featured__newcomer">
          New to Claude Code? Start at <a href="/start-here/foundations/">Foundations</a> or browse the <a href="/tips/">Tips</a> and <a href="/use-cases/">Use cases</a> first.
        </p>
        <div class="skills-featured__grid">
          <div class="skills-featured__cell">
            <p class="skills-featured__cell-label">1 — Access</p>
            <p class="skills-featured__cell-body">
              <strong>TBD</strong> — the AI team is finalising the access-request process. For now, ping the AI team channel on Teams and they'll add you to the repo.
            </p>
          </div>
          <div class="skills-featured__cell">
            <p class="skills-featured__cell-label">2 — Add the marketplace <span class="skills-featured__cell-hint">(once per machine)</span></p>
            <pre class="skills-featured__cmd"><code>/plugin marketplace add NBG-AI/claude-tools</code></pre>
          </div>
          <div class="skills-featured__cell">
            <p class="skills-featured__cell-label">3 — Install any skill from the library</p>
            <pre class="skills-featured__cmd"><code>/plugin install &lt;name&gt;@claude-tools</code></pre>
          </div>
        </div>
      </article>
    </div>
  </section>

  {grouped.map((group) => {
    if (group.items.length === 0) return null;
    const isInternalGroup = group.origin === 'internal';
    return (
      <section class="section section--listing" id={group.key}>
        <div class="wrap">
          <header class="listing-section__head">
            <h2 class="listing-section__title">{group.label}</h2>
            <p class="listing-section__lede">{group.blurb}</p>
          </header>
          <ul class="listing-list" role="list">
            {group.items.map((entry) => {
              const { command, explanation } = splitTitle(entry.data.title, entry.data.skill_id);
              return (
                <li>
                  <article
                    id={`skill-${entry.id}`}
                    class={`listing-row listing-row--linked${isInternalGroup ? ' listing-row--internal' : ''}`}
                    data-audience={entry.data.audience}
                    data-topics={entry.data.category}
                  >
                    <div class="listing-row__main">
                      <p class="listing-row__eyebrow">
                        Skill <span class="listing-row__eyebrow-sep">·</span> {group.label}
                      </p>
                      <h3 class="listing-row__title">
                        <a href={`/skills/${entry.id}/`} class="listing-row__title-link">{explanation}</a>
                      </h3>
                      <p class="listing-row__cmd">
                        <span class="listing-row__cmd-label">Type this in Claude</span>
                        <code class="listing-row__cmd-code">{command}</code>
                      </p>
                      <p class="listing-row__summary" set:html={linkGlossaryTerms(entry.data.ai_summary)} />
                    </div>
                    <div class="listing-row__meta">
                      {entry.data.time_saved && (
                        <span class="listing-pill listing-pill--time" title="Time you save per use (honest team estimate)">
                          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                          </svg>
                          <span>{entry.data.time_saved}</span>
                        </span>
                      )}
                      <span
                        class={`listing-pill listing-pill--audience listing-pill--audience-${entry.data.audience}`}
                        title={audienceTooltip(entry.data.audience)}
                      >
                        {entry.data.audience}
                      </span>
                      <div class="listing-row__pin">
                        <PinButton type="skill" slug={entry.id} iconOnly={true} />
                      </div>
                    </div>
                    <div class="listing-row__when">
                      <span class="listing-row__when-label">Use this when...</span>
                      <span class="listing-row__when-body" set:html={linkGlossaryTerms(entry.data.when_to_use.replace(/^[Uu]se this when ?/, ''))} />
                    </div>
                  </article>
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    );
  })}
</MarketingShell>

<script>
  import '../scripts/sticky-filter-bar.ts';
</script>

<style>
  @layer nbg.components {
    /* ─── Skills-only: let row prose use the full card width.
       Shared `.listing-row` is a `1fr auto` grid, and the meta column
       (time-saved pill + audience pill + pin) on skills can be wide
       enough to eat ~40% of the row — leaving the title, cmd chip, and
       summary visually stranded on the left. Two-part fix scoped to the
       cluster sections so /tips/ is untouched:
         1. Drop the row to a single column so `__main` spans full width.
         2. Float `__meta` absolutely into the top-right corner; reserve
            right padding on the eyebrow so they don't collide.
       The summary's 56rem readability cap is also lifted here, with a
       touch of right padding so the prose doesn't butt the meta block. */
    #internal .listing-row,
    #community .listing-row {
      grid-template-columns: 1fr !important;
      position: relative;
    }
    #internal .listing-row__meta,
    #community .listing-row__meta {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      justify-self: unset;
    }
    #internal .listing-row__eyebrow,
    #community .listing-row__eyebrow {
      padding-right: 22rem;  /* reserve space for the absolute-positioned meta */
    }
    #internal .listing-row__summary,
    #community .listing-row__summary {
      max-width: none !important;
      padding-right: 0.25rem;
    }

    /* ─── Featured panel: NBG AI plugin library ──────────────────── */
    .skills-featured {
      padding: 1.5rem 1.75rem 1.75rem;
      border: 1px solid color-mix(in srgb, #c79a3a 40%, var(--nbg-border, #dce3eb));
      border-radius: var(--nbg-r-lg, 12px);
      background: linear-gradient(
        135deg,
        color-mix(in srgb, #c79a3a 6%, var(--nbg-surface, #ffffff)) 0%,
        var(--nbg-surface, #ffffff) 80%
      );
      box-shadow: 0 2px 6px rgba(199, 154, 58, 0.08);
    }
    .skills-featured__eyebrow {
      margin: 0 0 0.5rem 0;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #8a6a1a;
      font-weight: 600;
    }
    /* Quiet single-line redirect for newcomers — sits under the lede, no
       box, smaller muted type. Meant to be skipped past by the target
       audience (developers) but visible to anyone who shouldn't be here yet. */
    .skills-featured__newcomer {
      margin: 0 0 1.1rem 0 !important;
      font-size: 0.82rem;
      line-height: 1.5;
      color: var(--nbg-muted, #5b6b80);
    }
    .skills-featured__newcomer :global(a) {
      color: var(--nbg-accent, #007a8a);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.18em;
    }
    .skills-featured__newcomer :global(a:hover) { text-decoration-thickness: 2px; }
    .skills-featured__title {
      font-family: var(--nbg-ff-serif, 'Newsreader', Georgia, serif) !important;
      font-weight: 500 !important;
      font-size: 1.5rem !important;
      line-height: 1.2 !important;
      letter-spacing: -0.015em !important;
      color: var(--nbg-ink, #0b1e2e) !important;
      margin: 0 0 0.6rem 0 !important;
    }
    .skills-featured__title :global(code) {
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.85em;
      background: color-mix(in srgb, #c79a3a 15%, transparent);
      color: #6f5212;
      padding: 0.08em 0.35em;
      border-radius: var(--nbg-r-sm, 4px);
    }
    .skills-featured__lede {
      margin: 0 0 1.1rem 0 !important;
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--nbg-ink-2, #1a3148);
    }
    .skills-featured__lede :global(code) {
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.88em;
      background: var(--nbg-surface-2, #f4f6fa);
      padding: 0.08em 0.32em;
      border-radius: var(--nbg-r-sm, 4px);
    }
    .skills-featured__lede :global(a) {
      color: #8a6a1a;
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.18em;
    }
    .skills-featured__lede :global(a:hover) { text-decoration-thickness: 2px; }
    .skills-featured__grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      /* Force every cell to the height of the tallest in the row. Default
         grid behaviour is `align-items: stretch`, but Starlight's unlayered
         cascade has been known to inject a row-level reset; setting it
         explicitly here protects against that. */
      align-items: stretch !important;
      gap: 0.85rem;
      margin: 0;
    }
    @media (max-width: 800px) {
      .skills-featured__grid { grid-template-columns: 1fr; }
    }
    .skills-featured__cell {
      padding: 0.85rem 0.95rem;
      border: 1px solid color-mix(in srgb, #c79a3a 25%, var(--nbg-hairline, #ebeff5));
      border-radius: var(--nbg-r-sm, 6px);
      background: var(--nbg-surface, #ffffff);
      /* Flex column so the label sits at the top and the command/body
         bottom-aligns across all three cells, no matter how the label
         wraps. */
      display: flex;
      flex-direction: column;
      /* Belt-and-braces: force the cell to fill its grid track. Without
         this, some browsers + cascade edge cases let the cell collapse to
         its content height even with align-items: stretch on the parent. */
      height: 100% !important;
      align-self: stretch !important;
      /* Starlight ships an unlayered `:not(...) + :not(...) { margin-top: 1rem }`
         rule that bleeds into our grid and pushes cells 2 and 3 down by 16px,
         visually offsetting them from cell 1. Same trap that listing-rows.css
         documents for <li>. Reset it explicitly. */
      margin: 0 !important;
    }
    .skills-featured__cell-label {
      margin: 0 0 0.4rem 0 !important;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.7rem;
      line-height: 1.45;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--nbg-ink, #0b1e2e);
      font-weight: 600;
      /* Reserve space for a two-line label so the single-line "ACCESS"
         label doesn't pull its body up above the wrapping labels in cells
         2 and 3. Combined with `margin-top: auto` on the body/cmd below
         this guarantees the dark command pills bottom-align cleanly. */
      min-height: calc(0.7rem * 1.45 * 2);
    }
    .skills-featured__cell-hint {
      font-size: 0.62rem;
      color: var(--nbg-muted, #5b6b80);
      letter-spacing: 0.08em;
      text-transform: none;
      font-weight: 400;
      margin-left: 0.25rem;
    }
    .skills-featured__cell-body {
      margin: 0 !important;
      font-size: 0.82rem;
      line-height: 1.5;
      color: var(--nbg-ink-2, #1a3148);
    }
    /* Push the terminating element (text body or `<pre>` command) to the
       bottom of its cell so they bottom-align across the three columns. */
    .skills-featured__cell-body,
    .skills-featured__cmd {
      margin-top: auto !important;
    }
    .skills-featured__cell-body :global(strong) {
      color: #8a6a1a;
      font-weight: 700;
    }
    .skills-featured__cmd {
      margin: 0 !important;
      padding: 0.6rem 0.7rem !important;
      background: #0b1e2e !important;
      color: #f0d493 !important;
      border-radius: var(--nbg-r-sm, 4px) !important;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace) !important;
      font-size: 0.75rem !important;
      line-height: 1.4 !important;
      overflow-x: auto;
    }
    .skills-featured__cmd :global(code) {
      background: transparent !important;
      color: inherit !important;
      padding: 0 !important;
    }
    /* ─── Internal-origin row accent (gold left edge so the cluster
           visually ties back to the featured panel above) ──────── */
    .listing-row--internal {
      border-left: 3px solid #c79a3a !important;
    }
    .listing-row--internal:hover {
      border-left-color: #c79a3a !important;
    }
  }
</style>
